<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Leek Channel Page</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background-color: #1a1a1a;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
            color: #ffffff;
        }
        .card {
            text-align: center;
            width: 90%;
            max-width: 400px;
            background: #2a2a2a;
            padding: 20px;
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        }
        .image-container {
            width: 100%;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 20px;
            background: #3a3a3a;
        }
        .image-container img {
            width: 100%;
            height: auto;
            display: block;
        }
        .text-label {
            font-size: 24px;
            font-weight: bold;
            color: #ffcc00;
            margin: 10px 0 0 0;
        }
    </style>
</head>
<body>

    <div class="card">
        <div class="image-container">
            <img src="https://i.postimg.cc/qMffg0X1/622.jpg" alt="Обезьяна">
        </div>
        <div class="text-label">Ульяна маймун</div>
    </div>

</body>
</html>
